rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Stripe customers collection (for subscription management)
    match /customers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow users to read their own subscriptions
      match /subscriptions/{subscriptionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }

      // Allow users to read their own payment methods
      match /payment_methods/{paymentMethodId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Public collections (readable by authenticated users)
    match /public/{document=**} {
      allow read: if true; // Public content
    }

    // CMS content (readable by all)
    match /cms/{document=**} {
      allow read: if true;
    }

    // Resources (readable by authenticated users)
    match /resources/{resourceId} {
      allow read: if request.auth != null;
    }

    // Events (readable by all)
    match /events/{eventId} {
      allow read: if true;
    }

    // Consultants (readable by all)
    match /consultants/{consultantId} {
      allow read: if true;
    }

    // Blog posts (readable by all)
    match /blogs/{blogId} {
      allow read: if true;
    }

    // Navigation and settings (readable by all)
    match /navigation/{navId} {
      allow read: if true;
    }

    match /settings/{settingId} {
      allow read: if true;
    }

    // Admin-only collections
    match /admin/{document=**} {
      allow read, write: if request.auth != null &&
        request.auth.token.admin == true;
    }

    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}